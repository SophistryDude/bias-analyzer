# Database
DATABASE_URL=postgresql://bias_analyzer:bias_analyzer_dev@127.0.0.1:5432/bias_analyzer

# YouTube Data API (for channel monitoring and video metadata)
# Get a key at: https://console.developers.google.com/
YOUTUBE_API_KEY=

# NYT Article Search API (free — metadata, headlines, abstracts)
# Register at: https://developer.nytimes.com/accounts/create
NYT_API_KEY=

# ProQuest API (full-text news archives via academic library)
# Contact WGU Library about ProQuest API/TDM Studio access
PROQUEST_API_KEY=
PROQUEST_BASE_URL=

# EBSCO EDS API (academic database access)
# Contact WGU Library about EBSCO API access
EBSCO_USER_ID=
EBSCO_PASSWORD=
EBSCO_PROFILE=edsapi

# Site URL (for RSS feed and meta tags)
NEXT_PUBLIC_BASE_URL=http://localhost:3000
